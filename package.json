{
  "name": "sennit",
  "version": "1.0.0",
  "description": "Sennit — aggregate MCP servers, parallel tool execution, and batch_call for strict hosts",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "author": "Spencer Wolf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alphabetsoup16/sennit.git"
  },
  "bugs": {
    "url": "https://github.com/Alphabetsoup16/sennit/issues"
  },
  "homepage": "https://github.com/Alphabetsoup16/sennit#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sennit",
    "parallel",
    "aggregator"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "bin": {
    "sennit": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli/index.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "lint": "eslint src tests",
    "validate": "npm run lint && npm run typecheck && npm test",
    "prepack": "npm run build"
  }
}
